#functions--define,parameter,return,print,
def find_primes(start, end): # defining a function and assigning a parameter
    primes = [n for n in range(start, end+1) if n > 1 and all(n % i != 0 for i in range(2, n))]
    return primes  #return
result = find_primes(1, 100)  
print(result)  #printing result




